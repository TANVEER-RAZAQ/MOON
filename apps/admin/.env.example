# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Admin panel basic-auth credentials (used by proxy.ts gate)
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASS=change-me-in-production

# Admin owner email pre-fill
NEXT_PUBLIC_ADMIN_OWNER_EMAIL=owner@moonbrand.com
